ALPACA_API_KEY=your-alpaca-api-key
ALPACA_API_SECRET=your-alpaca-api-secret
APP_ENV=production
ALPACA_PAPER=true
ALPACA_LIVE_TRADING_ENABLED=false
ALPACA_DATA_FEED=auto
ALPACA_STREAM_ALL=true
ALPACA_SYMBOLS=
ALPACA_TRADING_BASE_URL=
ALPACA_MARKET_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_MARKET_DATA_STREAM_URL=wss://stream.data.alpaca.markets
ALPACA_ORDER_FILL_TIMEOUT_SEC=20
ALPACA_ORDER_POLL_INTERVAL_SEC=1
POSTGRES_DB=momentum_bot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgres://postgres:postgres@db:5432/momentum_bot?sslmode=disable
HTTP_ADDR=:8080
SYMBOL_PROFILES_PATH=symbol-profiles.json
SNAPSHOT_PERSIST_INTERVAL_SEC=10
STARTUP_TIMEOUT_SEC=30
SHUTDOWN_TIMEOUT_SEC=10
STARTING_CAPITAL=100000
RISK_PER_TRADE_PCT=0.01
DAILY_LOSS_LIMIT_PCT=0.03
MAX_TRADES_PER_DAY=8
MAX_OPEN_POSITIONS=4
MAX_EXPOSURE_PCT=0.30
STOP_LOSS_PCT=0.05
PROFIT_TARGET_PCT=0.12
TRAILING_STOP_PCT=0.06
ENTRY_COOLDOWN_SEC=45
EXIT_COOLDOWN_SEC=5
SCANNER_WORKERS=6
SCANNER_MIN_PRICE=1
SCANNER_MIN_GAP_PCT=10
SCANNER_MIN_RELATIVE_VOLUME=5
SCANNER_MAX_FLOAT_SHARES=50000000
SCANNER_MIN_PREMARKET_VOLUME=500000
SCANNER_REQUIRE_SYMBOL_PROFILE=false
MARKET_DATA_HYDRATION_REQUESTS_PER_MIN=120
MARKET_DATA_HYDRATION_RETRY_SEC=300
MARKET_DATA_HYDRATION_QUEUE_SIZE=512
LIMIT_ORDER_SLIPPAGE_DOLLARS=0.10