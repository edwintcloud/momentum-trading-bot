# Required for the app
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_API_SECRET=your-alpaca-api-secret
DATABASE_URL=postgres://postgres:postgres@db:5432/momentum_bot?sslmode=disable
CONTROL_PLANE_AUTH_TOKEN=choose-a-long-random-token

# Safe defaults
ALPACA_PAPER=true
ALPACA_LIVE_TRADING_ENABLED=false
HTTP_ADDR=127.0.0.1:8080

# Optional overrides
ALPACA_SYMBOLS=

# Docker Compose Postgres defaults
POSTGRES_DB=momentum_bot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
